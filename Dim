    <script>
        // ========== SMOKE CANVAS ==========
        const canvas = document.getElementById('smokeCanvas');
        const ctx = canvas.getContext('2d');

        canvas.width  = window.innerWidth;
        canvas.height = window.innerHeight;

        window.addEventListener('resize', () => {
            canvas.width  = window.innerWidth;
            canvas.height = window.innerHeight;
        });

        class SmokeParticle {
            constructor() { this.reset(); }

            reset() {
                this.x      = Math.random() * canvas.width;
                this.y      = canvas.height + Math.random() * 200;
                this.radius = Math.random() * 120 + 40;
                this.speedY = -(Math.random() * 0.4 + 0.15);
                this.speedX = (Math.random() - 0.5) * 0.3;
                this.life   = 0;
                this.maxLife= Math.random() * 300 + 200;
                this.angle  = Math.random() * Math.PI * 2;
                this.spin   = (Math.random() - 0.5) * 0.004;
                this.alpha  = Math.random() * 0.12 + 0.04;
            }

            update() {
                this.y      += this.speedY;
                this.x      += this.speedX + Math.sin(this.angle) * 0.3;
                this.angle  += this.spin;
                this.radius += 0.18;
                this.life++;
                if (this.life > this.maxLife || this.y < -this.radius * 2) this.reset();
            }

            draw() {
                const progress = this.life / this.maxLife;
                const fade     = progress < 0.2
                    ? progress / 0.2
                    : progress > 0.7
                        ? 1 - (progress - 0.7) / 0.3
                        : 1;

                const gradient = ctx.createRadialGradient(
                    this.x, this.y, 0,
                    this.x, this.y, this.radius
                );
                gradient.addColorStop(0,   `rgba(200,169,110,${this.alpha * fade})`);
                gradient.addColorStop(0.4, `rgba(200,169,110,${this.alpha * fade * 0.5})`);
                gradient.addColorStop(1,   `rgba(200,169,110,0)`);

                ctx.save();
                ctx.translate(this.x, this.y);
                ctx.rotate(this.angle);
                ctx.translate(-this.x, -this.y);
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
                ctx.fillStyle = gradient;
                ctx.fill();
                ctx.restore();
            }
        }

        // Создаём частицы
        const particles = Array.from(
            { length: 28 },
            (_, i) => {
                const p = new SmokeParticle();
                p.life = Math.floor(Math.random() * p.maxLife);
                p.y    = Math.random() * canvas.height;
                return p;
            }
        );

        function animateSmoke() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            particles.forEach(p => { p.update(); p.draw(); });
            requestAnimationFrame(animateSmoke);
        }
        animateSmoke();

        // ========== SCROLL REVEAL ==========
        const revealEls = document.querySelectorAll('.reveal');

        const observer = new IntersectionObserver(
            entries => {
                entries.forEach(e => {
                    if (e.isIntersecting) {
                        e.target.classList.add('visible');
                        observer.unobserve(e.target);
                    }
                });
            },
            { threshold: 0.12 }
        );

        revealEls.forEach(el => observer.observe(el));

        // ========== ACTIVE NAV ==========
        const sections = document.querySelectorAll('section[id]');
        const navLinks  = document.querySelectorAll('.nav-links a');

        window.addEventListener('scroll', () => {
            let current = '';
            sections.forEach(sec => {
                if (window.scrollY >= sec.offsetTop - 120) {
                    current = sec.getAttribute('id');
                }
            });
            navLinks.forEach(a => {
                a.style.color = a.getAttribute('href') === `#${current}`
                    ? 'var(--gold)'
                    : '';
            });
        });

        // ========== DYNAMIC HOURS ==========
        const nowHours = (() => {
            const d   = document.querySelector('.contact-block .contact-value');
            if (!d) return;
            const now = new Date();
            const day = now.getDay(); // 0=вс,5=пт,6=сб
            const isWeekend = day === 5 || day === 6;
            d.textContent = isWeekend ? '16:00 — 04:00' : '16:00 — 02:00';
        })();

        // ========== PARALLAX HERO ==========
        const heroTitle = document.querySelector('.hero-title');
        window.addEventListener('scroll', () => {
            const y = window.scrollY;
            if (heroTitle && y < window.innerHeight) {
                heroTitle.style.transform = `translateY(${y * 0.25}px)`;
                heroTitle.style.opacity   = 1 - y / (window.innerHeight * 0.7);
            }
        });
    </script>

